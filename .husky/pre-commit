#!/bin/sh

if [ -t 1 ]; then
  reset="$(tput sgr0)"
  bold="$(tput bold)"
  dim="$(tput dim)"
  red="$(tput setaf 1)"
  green="$(tput setaf 2)"
  yellow="$(tput setaf 3)"
  blue="$(tput setaf 4)"
  magenta="$(tput setaf 5)"
  cyan="$(tput setaf 6)"
else
  reset=""
  bold=""
  dim=""
  red=""
  green=""
  yellow=""
  blue=""
  magenta=""
  cyan=""
fi

section() {
  printf "\n%s%s%s\n" "$bold$cyan" "$1" "$reset"
  printf "%s\n" "${dim}────────────────────────────────────────${reset}"
}

info() {
  printf "%s%s%s\n" "$blue" "$1" "$reset"
}

success() {
  printf "%s%s%s\n" "$green" "$1" "$reset"
}

warn() {
  printf "%s%s%s\n" "$yellow" "$1" "$reset"
}

fail() {
  printf "%s%s%s\n" "$red" "$1" "$reset"
}

section "✨ Pre-commit checks"
info "Formatting staged files..."

formatted_count=0
checked_count=0

# Prettier format staged files first
for file in $(git diff --cached --name-only --diff-filter=ACMR); do
  case "$file" in
  *.js|*.ts|*.tsx|*.mjs|*.json|*.css|*.md)
    if [ ! -f "$file" ]; then
      continue
    fi

    checked_count=$((checked_count + 1))
    printf "%s  🔎 %s%s\n" "$dim" "$file" "$reset"

    if npx prettier --check "$file" >/dev/null 2>&1; then
      success "  ✓ Already formatted"
    else
      npx prettier --write "$file" >/dev/null 2>&1 || {
        fail "  ✗ Formatting failed: $file"
        exit 1
      }

      git add "$file"
      formatted_count=$((formatted_count + 1))
      success "  ✓ Formatted"
    fi
    ;;
  esac
done

if [ "$checked_count" -eq 0 ]; then
  warn "ℹ No staged files matched formatting rules."
else
  success "✓ Formatting complete: $checked_count checked, $formatted_count changed."
fi

# Detect changed workspaces
staged_files=$(git diff --cached --name-only)

client_changed=false
server_changed=false
db_changed=false
types_changed=false
global_changed=false

for file in $staged_files; do
  case "$file" in
    apps/client/*)
      client_changed=true
      ;;
    apps/server/*)
      server_changed=true
      ;;
    packages/db/*)
      db_changed=true
      ;;
    packages/types/*)
      types_changed=true
      ;;
    package.json|package-lock.json|tsconfig.base.json|turbo.json)
      global_changed=true
      ;;
  esac
done

if [ "$global_changed" = true ]; then
  warn "⚙ Global config changed. Running lint and build for all workspaces."
  client_changed=true
  server_changed=true
  db_changed=true
  types_changed=true
fi

# Construct turbo filters
filters=""
workspace_names=""
if [ "$client_changed" = true ]; then
  filters="$filters --filter=@quizlytics/client"
  workspace_names="$workspace_names @quizlytics/client"
fi
if [ "$server_changed" = true ]; then
  filters="$filters --filter=@quizlytics/server"
  workspace_names="$workspace_names @quizlytics/server"
fi
if [ "$db_changed" = true ]; then
  filters="$filters --filter=@quizlytics/db"
  workspace_names="$workspace_names @quizlytics/db"
fi
if [ "$types_changed" = true ]; then
  filters="$filters --filter=@quizlytics/types"
  workspace_names="$workspace_names @quizlytics/types"
fi

if [ -z "$filters" ]; then
  success "✨ No workspace files modified. Skipping lint and build."
else
  section "🔍 Type, lint, and build"
  info "Workspaces:$workspace_names"
  printf "%sCommand:%s npx turbo run lint build%s\n\n" "$dim" "$reset" "$filters"

  # Run lint and build for changed workspaces
  npx turbo run lint build $filters || {
    fail "❌ Checks failed. Commit blocked."
    exit 1
  }
fi

success "✅ All checks passed."
