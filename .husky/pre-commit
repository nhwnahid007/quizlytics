#!/bin/sh

if [ -t 1 ]; then
  reset="$(tput sgr0)"
  bold="$(tput bold)"
  dim="$(tput dim)"
  red="$(tput setaf 1)"
  green="$(tput setaf 2)"
  yellow="$(tput setaf 3)"
  blue="$(tput setaf 4)"
  cyan="$(tput setaf 6)"
else
  reset=""
  bold=""
  dim=""
  red=""
  green=""
  yellow=""
  blue=""
  cyan=""
fi

section() {
  printf "\n%s%s%s\n" "$bold$cyan" "$1" "$reset"
  printf "%s\n" "${dim}----------------------------------------${reset}"
}

info() {
  printf "%s%s%s\n" "$blue" "$1" "$reset"
}

success() {
  printf "%s%s%s\n" "$green" "$1" "$reset"
}

warn() {
  printf "%s%s%s\n" "$yellow" "$1" "$reset"
}

fail() {
  printf "%s%s%s\n" "$red" "$1" "$reset"
}

append_filter() {
  case " $1 " in
    *" $2 "*) printf "%s" "$1" ;;
    *) printf "%s --filter=%s" "$1" "$2" ;;
  esac
}

append_name() {
  case " $1 " in
    *" $2 "*) printf "%s" "$1" ;;
    *) printf "%s %s" "$1" "$2" ;;
  esac
}

section "Pre-commit checks"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  warn "No staged files. Skipping checks."
  exit 0
fi

client_changed=false
server_changed=false
db_changed=false
types_changed=false
global_changed=false

for file in $staged_files; do
  case "$file" in
    apps/client/*)
      client_changed=true
      ;;
    apps/server/*)
      server_changed=true
      ;;
    packages/db/*)
      db_changed=true
      ;;
    packages/types/*)
      types_changed=true
      ;;
    package.json|package-lock.json|tsconfig.base.json|turbo.json|commitlint.config.js)
      global_changed=true
      ;;
  esac
done

lint_filters=""
lint_names=""
build_filters=""
build_names=""

if [ "$global_changed" = true ]; then
  warn "Global config changed. Running all workspace checks."
  lint_filters=""
  lint_names="all workspaces"
  build_filters=""
  build_names="all workspaces"
else
  if [ "$client_changed" = true ]; then
    lint_filters="$(append_filter "$lint_filters" "@quizlytics/client")"
    lint_names="$(append_name "$lint_names" "@quizlytics/client")"
    build_filters="$(append_filter "$build_filters" "@quizlytics/client")"
    build_names="$(append_name "$build_names" "@quizlytics/client + dependencies")"
  fi

  if [ "$server_changed" = true ]; then
    lint_filters="$(append_filter "$lint_filters" "@quizlytics/server")"
    lint_names="$(append_name "$lint_names" "@quizlytics/server")"
    build_filters="$(append_filter "$build_filters" "@quizlytics/server")"
    build_names="$(append_name "$build_names" "@quizlytics/server + dependencies")"
  fi

  if [ "$types_changed" = true ]; then
    build_filters="$(append_filter "$build_filters" "@quizlytics/types...")"
    build_names="$(append_name "$build_names" "@quizlytics/types + dependents")"
  fi

  if [ "$db_changed" = true ]; then
    build_filters="$(append_filter "$build_filters" "@quizlytics/db...")"
    build_names="$(append_name "$build_names" "@quizlytics/db + dependents")"
  fi
fi

if [ -n "$lint_filters" ] || [ "$global_changed" = true ]; then
  section "Lint"
  info "Targets: $lint_names"
  if [ "$global_changed" = true ]; then
    npx turbo run lint || {
      fail "Lint failed. Commit blocked."
      exit 1
    }
  else
    npx turbo run lint $lint_filters || {
      fail "Lint failed. Commit blocked."
      exit 1
    }
  fi
else
  success "Lint skipped. No changed workspace has a lint task."
fi

if [ -n "$build_filters" ] || [ "$global_changed" = true ]; then
  section "Build"
  info "Targets: $build_names"
  if [ "$global_changed" = true ]; then
    npx turbo run build || {
      fail "Build failed. Commit blocked."
      exit 1
    }
  else
    npx turbo run build $build_filters || {
      fail "Build failed. Commit blocked."
      exit 1
    }
  fi
else
  success "Build skipped. No workspace files changed."
fi

section "Format"
formatted_count=0
checked_count=0

for file in $staged_files; do
  case "$file" in
    *.js|*.ts|*.tsx|*.mjs|*.json|*.css|*.md)
      if [ ! -f "$file" ]; then
        continue
      fi

      checked_count=$((checked_count + 1))
      printf "%s  %s%s\n" "$dim" "$file" "$reset"

      if npx prettier --check "$file" >/dev/null 2>&1; then
        success "  already formatted"
      else
        npx prettier --write "$file" >/dev/null 2>&1 || {
          fail "Formatting failed: $file"
          exit 1
        }
        git add "$file"
        formatted_count=$((formatted_count + 1))
        success "  formatted"
      fi
      ;;
  esac
done

if [ "$checked_count" -eq 0 ]; then
  warn "No staged files matched formatting rules."
else
  success "Format complete: $checked_count checked, $formatted_count changed."
fi

success "All checks passed."
