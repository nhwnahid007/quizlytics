#!/bin/sh

# 1. Colors and Formatting
if [ -t 1 ]; then
  reset="$(tput sgr0)"
  bold="$(tput bold)"
  dim="$(tput dim)"
  red="$(tput setaf 1)"
  green="$(tput setaf 2)"
  yellow="$(tput setaf 3)"
  blue="$(tput setaf 4)"
  cyan="$(tput setaf 6)"
else
  reset=""
  bold=""
  dim=""
  red=""
  green=""
  yellow=""
  blue=""
  cyan=""
fi

section() {
  printf "\n%s⚡ %s%s\n" "$bold$cyan" "$1" "$reset"
  printf "%s\n" "${dim}────────────────────────────────────────────────────────────────────────${reset}"
}

info() {
  printf "%sℹ️  %s%s\n" "$blue" "$1" "$reset"
}

success() {
  printf "%s✅ %s%s\n" "$green" "$1" "$reset"
}

warn() {
  printf "%s⚠️  %s%s\n" "$yellow" "$1" "$reset"
}

fail() {
  printf "%s❌ %s%s\n" "$red" "$1" "$reset"
}

# 2. Resolve fast local binaries (Avoids slow npx lookup)
resolve_bin() {
  _bin="./node_modules/.bin/$1"
  if [ -x "$_bin" ]; then
    printf "%s" "$_bin"
  else
    printf "npx --no-install %s" "$1"
  fi
}

append_filter() {
  case " $1 " in
    *" $2 "*) printf "%s" "$1" ;;
    *) printf "%s --filter=%s" "$1" "$2" ;;
  esac
}

append_name() {
  case " $1 " in
    *" $2 "*) printf "%s" "$1" ;;
    *) printf "%s %s" "$1" "$2" ;;
  esac
}

section "Pre-commit checks"

# Retrieve staged files
staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  warn "No staged files found. Skipping all checks."
  exit 0
fi

# Resolve optimized local binaries
TURBO_BIN="$(resolve_bin turbo)"
PRETTIER_BIN="$(resolve_bin prettier)"

client_changed=false
server_changed=false
db_changed=false
types_changed=false
global_changed=false

# Handle spaces and newlines in filenames by setting IFS to newline
OLD_IFS="$IFS"
IFS='
'
for file in $staged_files; do
  case "$file" in
    apps/client/*)
      client_changed=true
      ;;
    apps/server/*)
      server_changed=true
      ;;
    packages/db/*)
      db_changed=true
      ;;
    packages/types/*)
      types_changed=true
      ;;
    package.json|package-lock.json|tsconfig.base.json|turbo.json|commitlint.config.js)
      global_changed=true
      ;;
  esac
done
IFS="$OLD_IFS"

lint_filters=""
lint_names=""

if [ "$global_changed" = true ]; then
  warn "Global config changed. Running all workspace checks."
  lint_filters=""
  lint_names="all workspaces"
else
  if [ "$client_changed" = true ]; then
    lint_filters="$(append_filter "$lint_filters" "@quizlytics/client")"
    lint_names="$(append_name "$lint_names" "@quizlytics/client")"
  fi

  if [ "$server_changed" = true ]; then
    lint_filters="$(append_filter "$lint_filters" "@quizlytics/server")"
    lint_names="$(append_name "$lint_names" "@quizlytics/server")"
  fi
fi

# Run Lint
if [ -n "$lint_filters" ] || [ "$global_changed" = true ]; then
  section "Linting Code"
  info "Targets: $lint_names"
  if [ "$global_changed" = true ]; then
    $TURBO_BIN run lint || {
      fail "Lint failed. Commit blocked."
      exit 1
    }
  else
    $TURBO_BIN run lint $lint_filters || {
      fail "Lint failed. Commit blocked."
      exit 1
    }
  fi
else
  success "Lint skipped. No changed workspace has a lint task."
fi

# Format with Prettier
section "Code Formatting"
prettier_files=""
checked_count=0

OLD_IFS="$IFS"
IFS='
'
for file in $staged_files; do
  case "$file" in
    *.js|*.ts|*.tsx|*.mjs|*.json|*.css|*.md)
      if [ -f "$file" ]; then
        # Escape single quotes in filenames for the eval safety
        escaped_file=$(printf "%s" "$file" | sed "s/'/'\\\\''/g")
        prettier_files="$prettier_files '$escaped_file'"
        checked_count=$((checked_count + 1))
      fi
      ;;
  esac
done
IFS="$OLD_IFS"

if [ "$checked_count" -eq 0 ]; then
  warn "No staged files matched formatting rules."
else
  info "Checking & formatting $checked_count files in a single batch..."
  
  # Run prettier write on all files at once (10x-50x faster!)
  eval "$PRETTIER_BIN --write $prettier_files" || {
    fail "Formatting failed. Commit blocked."
    exit 1
  }
  
  # Re-stage all formatted files to git index
  eval "git add $prettier_files"
  success "Format complete: $checked_count files checked and formatted successfully!"
fi

success "All pre-commit checks passed successfully! 🚀 Ready to commit."
