{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "STRIPE_SECRET_KEY",
    "AUTH_SECRET",
    "NEXTAUTH_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_ID",
    "GITHUB_SECRET",
    "DATABASE_URL",
    "AI_API_KEY",
    "AI_MODEL",
    "ALLOWED_ORIGINS",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_STRIPE_PUBLIC_KEY",
    "NEXT_PUBLIC_IMG_HOSTING_KEY",
    "NEXT_PUBLIC_EMAILJS_SERVICE_ID",
    "NEXT_PUBLIC_EMAILJS_TEMPLATE_ID",
    "NEXT_PUBLIC_EMAILJS_PUBLIC_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["@quizlytics/db#build", "@quizlytics/types#build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "@quizlytics/db#build": {
      "outputs": ["dist/**"]
    },
    "@quizlytics/types#build": {
      "dependsOn": ["@quizlytics/db#build"],
      "outputs": ["dist/**"]
    },
    "@quizlytics/server#build": {
      "dependsOn": ["@quizlytics/db#build", "@quizlytics/types#build"],
      "outputs": ["dist/**"]
    },
    "@quizlytics/client#build": {
      "dependsOn": ["@quizlytics/db#build", "@quizlytics/types#build"],
      "outputs": [".next/**", "!.next/cache/**"]
    }
  }
}
